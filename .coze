[project]
sub_id = "c9f3780e"
name = "wawu-world-2"
requires = ["nodejs-22"]
project_type = "web"

[preview]
preview_enable = "enabled"

[dev]
build = ["bash", "scripts/coze-preview-build.sh"]
run = ["bash", "scripts/coze-preview-run.sh"]

[deploy]
build = ["bash", ".cozeproj/scripts/deploy_build.sh"]
run = ["bash", ".cozeproj/scripts/deploy_run.sh"]

[deploy.profile]
kind = "service"
flavor = "web"

[deploy.backend]
enabled = true

[subprojects]
path = ["."]
